rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function myRole() {
      return get(/databases/$(database)/documents/team/$(request.auth.uid)).data.role;
    }
    function isOwner() {
      return isSignedIn() && myRole() == 'Owner';
    }

    match /team/{id} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }
    match /clients/{id} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }
    match /invoices/{id} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }
    match /projects/{id} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }
    match /tasks/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /learningItems/{id} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }
  }
}
